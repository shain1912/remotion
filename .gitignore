# Scratch & logs under factory/_* are ignored, but the reusable pipeline
# scripts (place-audio / audio-check / chunk-voice / metrics / lambda / phase) are kept.
factory/_*
!factory/_place-audio.mjs
!factory/_audio-check.mjs
!factory/_audio-qc.mjs
!factory/_chunk_voice.mjs
!factory/_metrics.mjs
!factory/_lambda-render-one.sh
!factory/_phase-a.sh
!factory/_phase-b.sh
!factory/_prep-lambda.sh

